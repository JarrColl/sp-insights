{
  "name": "boilerplate-solid-js",
  "version": "1.0.0",
  "description": "Solid.js Boilerplate Plugin for Super Productivity",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "package": "node scripts/build-plugin.js",
    "deploy": "pnpm run build",
    "postinstall": "cd node_modules/@super-productivity/vite-plugin && npm install && npx tsc"
  },
  "devDependencies": {
    "@solidjs/router": "^0.15.4",
    "@solidjs/testing-library": "^0.8.10",
    "@super-productivity/vite-plugin": "github:super-productivity/super-productivity#master&path:packages/vite-plugin",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "archiver": "^7.0.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-solid": "^0.14.5",
    "jsdom": "^27.4.0",
    "prettier": "^3.8.3",
    "solid-js": "^1.9.12",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "packageExtensions": {
      "@super-productivity/vite-plugin": {
        "scripts": {
          "prepare": "npm run build"
        }
      }
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "@super-productivity/vite-plugin"
    ]
  }
}
